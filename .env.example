# Project Info
PROJECT_NAME="Clean Architecture FastAPI"
ENVIRONMENT=local

# CORS configuration (JSON-parsed list of origins)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# PostgreSQL configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
POSTGRES_PORT=5432

# Security & Auth
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=secret-key-placeholder-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gemini LLM Settings (Optional - falls back to local LLM if empty)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Local LLM settings (Ollama)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# S3 Object Storage Configuration
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Celery / Redis (task queue)
# For Docker: redis://redis:6379/0
# For local dev: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Export — temporary directory for packaged ZIP files
EXPORT_TEMP_DIR=/tmp/clanker_exports
